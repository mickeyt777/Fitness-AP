# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite file. In production: /var/data/fitnessap.db
DB_PATH=./data/fitnessap.db

# Port the Express server listens on.
PORT=3000

# ── Encryption ────────────────────────────────────────────────────────────────
# AES-256-GCM key for sensitive columns (drug, dose, measurements).
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Leave blank in development — data will be stored in plaintext with a warning.
# REQUIRED in production. If you change this after launch, existing data cannot be decrypted.
ENCRYPTION_KEY=

# ── Apple auth (Sign in with Apple) ──────────────────────────────────────────
# Your app's bundle ID — used to verify Apple identity tokens.
# e.g. com.yourname.fitnessap
APPLE_BUNDLE_ID=

# ── Development ───────────────────────────────────────────────────────────────
# Set to 'production' on the VPS. Leave unset or 'development' locally.
NODE_ENV=development

# Set to 'true' to skip subscription checks during local dev/testing.
# NEVER set this to true in production.
SKIP_SUBSCRIPTION_CHECK=true

# ── Cloud LLM (for AI-powered features) ──────────────────────────────────────
# Provider: 'anthropic' or 'openai' (set the matching API key below)
CLOUD_LLM_PROVIDER=anthropic
CLOUD_LLM_API_KEY=

# ── Apple Push Notifications (APNs) ──────────────────────────────────────────
# From your Apple Developer account → Certificates → Keys.
# Until these are set, notifications are logged but not sent (stub mode).
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_KEY_PATH=./AuthKey_XXXXXXXXXX.p8

# ── RevenueCat webhooks ───────────────────────────────────────────────────────
# The webhook secret from your RevenueCat dashboard.
# Until set, signature verification is skipped in dev (warning logged).
REVENUECAT_WEBHOOK_SECRET=

# ── Backblaze B2 (photo storage) ─────────────────────────────────────────────
# Credentials for the photo upload bucket.
# Until set, photo uploads are stubbed (accepted but not sent to B2).
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=fitnessap-photos
# Find your endpoint in the B2 console (varies by region).
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
